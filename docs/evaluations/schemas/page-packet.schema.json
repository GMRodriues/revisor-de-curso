{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "PagePacket",
  "type": "object",
  "required": [
    "packetVersion",
    "runId",
    "pageId",
    "location",
    "url",
    "capturedAt",
    "viewport",
    "status",
    "artifacts"
  ],
  "properties": {
    "packetVersion": {
      "type": "string",
      "const": "1.0"
    },
    "runId": {
      "type": "string"
    },
    "pageId": {
      "type": "string"
    },
    "location": {
      "type": "object",
      "required": ["course"],
      "properties": {
        "course": { "type": "string" },
        "courseId": { "type": "string" },
        "module": { "type": "string" },
        "moduleId": { "type": "string" },
        "lesson": { "type": "string" },
        "lessonId": { "type": "string" },
        "section": { "type": "string" },
        "page": { "type": "string" },
        "pageIndex": { "type": "integer", "minimum": 0 },
        "platformUnitId": { "type": "string" }
      },
      "additionalProperties": true
    },
    "url": {
      "type": "string"
    },
    "canonicalUrl": {
      "type": "string"
    },
    "capturedAt": {
      "type": "string"
    },
    "viewport": {
      "type": "object",
      "required": ["width", "height"],
      "properties": {
        "name": { "type": "string" },
        "width": { "type": "integer" },
        "height": { "type": "integer" },
        "deviceScaleFactor": { "type": "number" }
      },
      "additionalProperties": true
    },
    "navigation": {
      "type": "object",
      "properties": {
        "method": { "type": "string" },
        "previousUrl": { "type": "string" },
        "nextUrl": { "type": "string" },
        "previousControlDetected": { "type": "boolean" },
        "nextControlDetected": { "type": "boolean" },
        "sequenceStatus": {
          "type": "string",
          "enum": ["ok", "missing_previous", "missing_next", "ambiguous", "not_applicable", "blocked"]
        }
      },
      "additionalProperties": true
    },
    "status": {
      "type": "object",
      "required": ["visited", "loaded", "captureCompleteness"],
      "properties": {
        "visited": { "type": "boolean" },
        "loaded": { "type": "boolean" },
        "stable": { "type": "boolean" },
        "captureCompleteness": {
          "type": "string",
          "enum": ["complete", "partial", "blocked"]
        },
        "blockedReason": { "type": "string" },
        "manualReviewReason": { "type": "string" },
        "loadMs": { "type": "integer", "minimum": 0 }
      },
      "additionalProperties": true
    },
    "content": {
      "type": "object",
      "properties": {
        "visibleTitle": { "type": "string" },
        "expectedContentTypes": {
          "type": "array",
          "items": { "type": "string" }
        },
        "detectedContentTypes": {
          "type": "array",
          "items": { "type": "string" }
        },
        "visibleTextChars": { "type": "integer", "minimum": 0 },
        "language": { "type": "string" }
      },
      "additionalProperties": true
    },
    "mediaSummary": {
      "type": "object",
      "properties": {
        "images": { "type": "integer", "minimum": 0 },
        "brokenImages": { "type": "integer", "minimum": 0 },
        "videos": { "type": "integer", "minimum": 0 },
        "videosWithTranscript": { "type": "integer", "minimum": 0 },
        "videosWithSummary": { "type": "integer", "minimum": 0 },
        "iframes": { "type": "integer", "minimum": 0 }
      },
      "additionalProperties": true
    },
    "linkSummary": {
      "type": "object",
      "properties": {
        "internalLinks": { "type": "integer", "minimum": 0 },
        "externalLinks": { "type": "integer", "minimum": 0 },
        "downloads": { "type": "integer", "minimum": 0 },
        "brokenLinks": { "type": "integer", "minimum": 0 },
        "externalLinksMissingNewTabWarning": { "type": "integer", "minimum": 0 }
      },
      "additionalProperties": true
    },
    "activitySummary": {
      "type": "object",
      "properties": {
        "activities": { "type": "integer", "minimum": 0 },
        "questions": { "type": "integer", "minimum": 0 },
        "feedbackVisibleWithoutSubmit": { "type": "boolean" },
        "submissionRequiredForFeedback": { "type": "boolean" },
        "destructiveInteractionSkipped": { "type": "boolean" }
      },
      "additionalProperties": true
    },
    "artifacts": {
      "type": "object",
      "required": ["pageJson"],
      "properties": {
        "pageJson": { "type": "string" },
        "visibleText": { "type": "string" },
        "domSnapshot": { "type": "string" },
        "fullpageScreenshot": { "type": "string" },
        "viewportScreenshot": { "type": "string" },
        "media": { "type": "string" },
        "links": { "type": "string" },
        "interactions": { "type": "string" },
        "console": { "type": "string" },
        "network": { "type": "string" },
        "notes": { "type": "string" }
      },
      "additionalProperties": true
    },
    "checks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "status"],
        "properties": {
          "id": { "type": "string" },
          "status": {
            "type": "string",
            "enum": ["passed", "failed", "blocked", "manual_review", "skipped_with_reason"]
          },
          "evidence": {
            "type": "array",
            "items": { "type": "string" }
          },
          "notes": { "type": "string" }
        },
        "additionalProperties": true
      }
    },
    "findings": {
      "type": "array",
      "items": {
        "oneOf": [
          { "type": "string" },
          {
            "type": "object",
            "required": ["id", "contextScreenshot"],
            "properties": {
              "id": { "type": "string" },
              "contextScreenshot": { "type": "string" },
              "focusedScreenshot": { "type": "string" },
              "notes": { "type": "string" }
            },
            "additionalProperties": true
          }
        ]
      }
    },
    "captureGaps": {
      "type": "array",
      "items": { "type": "string" }
    }
  },
  "additionalProperties": false
}
